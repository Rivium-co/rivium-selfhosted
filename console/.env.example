# ================================================
# Rivium Console Self-Hosted Configuration
# ================================================

# JWT Secrets (change these to random strings)
JWT_SECRET=change-this-to-a-random-string
JWT_REFRESH_SECRET=change-this-to-another-random-string

# Database
POSTGRES_DB=rivium_console
POSTGRES_USER=rivium
POSTGRES_PASSWORD=change-this-too

# Ports
DASHBOARD_PORT=3000
API_PORT=3004

# ================================================
# Connect your Rivium self-hosted services below
# Only set the URLs for services you have installed
# ================================================

# RiviumTrace (Error Tracking & APM)
NEXT_PUBLIC_RIVIUM_TRACE_API_URL=http://localhost:3001/api

# Console API (auto-configured, don't change unless custom setup)
NEXT_PUBLIC_API_URL=http://localhost:3004

# Email (optional — for password reset, team invitations)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=
