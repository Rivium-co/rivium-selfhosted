# ================================================
# RiviumTrace Self-Hosted Configuration
# ================================================

# License Key — leave empty for free tier
# Activate via Dashboard → License page after setup
LICENSE_KEY=

# JWT Secret (change to a random string)
JWT_SECRET=change-this-to-a-random-string

# Database
POSTGRES_DB=rivium_trace
POSTGRES_USER=rivium
POSTGRES_PASSWORD=change-this-too

# Console connection (for dashboard auth)
# On Mac/Windows: host.docker.internal works
# On Linux: use 172.17.0.1 or your server IP
CONSOLE_API_URL=http://host.docker.internal:3004
RIVIUM_TRACE_DOMAIN=http://localhost:3000

# Email for alerts (optional)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=

# Source maps — defaults to local disk
# For S3-compatible storage (AWS S3, Cloudflare R2, MinIO):
# S3_ENDPOINT=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_BUCKET=
# S3_REGION=
